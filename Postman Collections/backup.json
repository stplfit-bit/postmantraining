				{
					"name": "GET / pet/{petId}",
					"item": [
						{
							"name": "Get pet by id",
							"event": [
								{
									"listen": "prerequest",
									"script": {
										"id": "1e586c1a-c7c5-4bda-b822-72eb9799db31",
										"exec": [
											"const postPetRequest = {",
											"    url: pm.globals.get(\"base url\")+'pet',",
											"    method: 'POST',",
											"    header: {",
											"        'Content-Type': 'application/json'",
											"    },",
											"    body: JSON.stringify({",
											"          \"id\": 0,",
											"  \"category\": {",
											"    \"id\": 0,",
											"    \"name\": \"Tom\"",
											"  },",
											"  \"name\": \"doggie\",",
											"  \"photoUrls\": [",
											"    \"string\"",
											"  ],",
											"  \"tags\": [",
											"    {",
											"      \"id\": 0,",
											"      \"name\": \"string\"",
											"    }",
											"  ],",
											"  \"status\": \"available\"",
											"    })",
											"};",
											"",
											"pm.sendRequest(postPetRequest, function (error, response) {",
											"",
											"    let responseText = response.text().replace(",
											"        /([^\\w-])([-0-9.]{8,100})([^\\w-])/g,",
											"        '$1\"$2\"$3'",
											"    );",
											"    let jsonData = JSON.parse(responseText);",
											"    let id = jsonData.id.replace('\"', '');",
											"",
											"console.log(\"pet id is \" + id);",
											"pm.environment.set(\"pet_id\", id);",
											"",
											"pm.test(\"Status code is 200\", function () {",
											"    pm.expect(response).to.have.status(200);});",
											"});"
										],
										"type": "text/javascript",
										"packages": {},
										"requests": {}
									}
								},
								{
									"listen": "test",
									"script": {
										"id": "d2bdf4d3-c81c-4743-82ab-11835389015d",
										"exec": [
											"pm.test(\"Status code is 200\", function () {",
											"    pm.response.to.have.status(200);",
											"});",
											"pm.test(\"Response contains required properties\", function () {",
											"    const jsonData = pm.response.json();",
											"",
											"    pm.expect(jsonData).to.have.property(\"id\");",
											"    pm.expect(jsonData).to.have.property(\"category\");",
											"    pm.expect(jsonData).to.have.property(\"name\");",
											"    pm.expect(jsonData).to.have.property(\"photoUrls\");",
											"    pm.expect(jsonData).to.have.property(\"tags\");",
											"    pm.expect(jsonData).to.have.property(\"status\");",
											"});",
											"",
											"pm.test(\"Tag Id\", function () {",
											"    var jsonData = pm.response.json();",
											"    pm.expect(jsonData.tags[0].id).to.eql(0);",
											"    pm.expect(jsonData.tags[0].name).to.eql(\"string\");",
											"});",
